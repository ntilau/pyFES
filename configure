#!/usr/bin/env bash
set -euo pipefail

# pyFES — setup script
# Creates a virtual environment, installs the package with all
# dependencies, and verifies the installation.
#
# Usage:
#   ./configure                    # standard install
#   ./configure --dev              # include dev / ML extras
#   ./configure --minimal          # FEM-only, skip ML libs

HERE="$(cd "$(dirname "$0")" && pwd)"
VENV="$HERE/.venv"

MODE="${1:-standard}"

echo "=== pyFES setup ==="

# 1. Create virtual environment
if [ ! -d "$VENV" ]; then
    echo "Creating virtual environment ..."
    python3 -m venv "$VENV"
fi

echo "Installing package + dependencies ..."
"$VENV/bin/pip" install --quiet --upgrade pip
"$VENV/bin/pip" install --quiet -e "$HERE[viz]"
"$VENV/bin/pip" install --quiet pytest

# 2. Optional extras
case "$MODE" in
    --dev)
        echo "Installing ML / DNN-GP dependencies ..."
        "$VENV/bin/pip" install --quiet torch gpytorch scikit-learn
        ;;
    --minimal)
        echo "Skipping ML dependencies (FEM-only mode)."
        ;;
    *)
        echo "Installing ML / DNN-GP dependencies ..."
        "$VENV/bin/pip" install --quiet torch gpytorch scikit-learn
        ;;
esac

# 3. Verify
echo "Verifying installation ..."
"$VENV/bin/python" -c "
from pyfes import constants
print(f'pyFES OK')
try:
    import torch; print(f'  torch {torch.__version__}')
except: pass
try:
    import gpytorch; print(f'  gpytorch {gpytorch.__version__}')
except: pass
"

# 4. Check for mesh data
echo ""
if [ -d "$HERE/data" ] && ls "$HERE/data"/*.poly &>/dev/null 2>&1; then
    echo "Mesh files:  found in data/"
else
    echo "Mesh files:  none (generate with iormesh/ or download separately)"
fi

# Verify at least one project can import
PYVER="$("$VENV/bin/python" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
echo "Python:      $PYVER"
echo "Package:     pyFES 0.2.0"
echo ""
echo "Quick test:  $VENV/bin/python -m pytest tests/ -v"
echo "Run FDFD:    $VENV/bin/python -c 'from pyfes.projects import run_waveguide; run_waveguide()'"
echo "Run DNN-GP:  $VENV/bin/python -c 'from pyfes.projects import bilateral_filter_dnngp; print(\"import OK\")'"
echo ""
echo "=== done ==="
